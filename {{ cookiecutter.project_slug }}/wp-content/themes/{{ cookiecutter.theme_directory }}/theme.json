{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 2,
	"settings": {
		"color": {
			"palette": [
				{
					"slug": "cream",
					"color": "#F8F6F2",
					"name": "Cream"
				},
				{
					"slug": "charcoal",
					"color": "#23262A",
					"name": "Charcoal"
				}
			]
		},
		"layout": {
            "contentSize": "840px",
            "wideSize": "1100px"
        },
		"spacing": {
			"margin": true,
			"padding": true,
			"blockGap": true
		},
		"typography": {
			"fontFamilies": [
                {
					"name": "Cormorant Garamond",
					"slug": "cormorant-garamond",
					"fontFamily": "'Cormorant Garamond', serif",
					"fontFace": [
						{
							"fontFamily": "Cormorant Garamond",
							"fontWeight": "300 800",
							"fontStyle": "normal",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/CormorantGaramond-Regular.woff2" ]
						},
						{
							"fontFamily": "Cormorant Garamond",
							"fontWeight": "300 800",
							"fontStyle": "italic",
							"fontStretch": "normal",
							"src": [ "file:./assets/fonts/CormorantGaramond-Italic.woff2" ]
						}
					]
				}
			],
			"lineHeight": true
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|cream",
			"text": "var:preset|color|charcoal"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--cormorant-garamond)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant-garamond)"
				}
			}
		}
	}
}